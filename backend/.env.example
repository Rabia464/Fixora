# Fixora Backend - Environment Variables Example
# Copy this file to .env and fill in the values before running the application.

# Application Settings
PROJECT_NAME="Fixora API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
DEBUG=True

# Security
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY="your-super-secret-key-change-me-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Database Settings (PostgreSQL via asyncpg)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-db-password"
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="fixora"
# Database URL is automatically constructed by the Settings class in config.py
